  "scripts": {
    "start": "npm run dev:web",
    "build": "npm run build:web",
    "dev:web": "vite",
    "dev:electron": "vite --config vite.electron.config.ts",
    "build:web": "node DownloadTranslations.js && vite build",
    "build:electron": "tsc && vite build --config vite.electron.config.ts && electron-builder",
    "build:electron:nopublish": "tsc && vite build --config vite.electron.config.ts && electron-builder --publish never",
    "translate:build": "node DownloadTranslations.js && vite build",
    "build-size": "du -sh dist/",
    "serve": "npx serve dist",
    "local-deploy": "node DownloadTranslations.js && vite build && npx serve dist",
    "deploy": "node DownloadTranslations.js && vite build && firebase deploy",
    "translate": "node DownloadTranslations.js",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0"
  },
